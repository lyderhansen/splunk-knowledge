{
    "showTitleAndDescription": true,
    "includeInToolbar": true,
    "includeInVizSwitcher": true,
    "showDrilldown": true,
    "hasEventHandlers": true,
    "canSetTokens": ["dynamic"],
    "config": {
        "name": "Red Bull Ring Gauge",
        "description": "Arc ring gauge with Red Bull threshold coloring (danger/warn/success) and gold accent glow.",
        "category": "Custom",
        "dataContract": { "requiredDataSources": ["primary"] },
        "size": { "initialWidth": 500, "initialHeight": 300 },
        "optionsSchema": {
            "themeMode":    { "type": "string",  "default": "auto" },
            "minValue":     { "type": "number",  "default": 0 },
            "maxValue":     { "type": "number",  "default": 100 },
            "arcWidth":     { "type": "number",  "default": 22 },
            "showLabel":    { "type": "boolean", "default": true },
            "accentColor":  { "type": "string",  "default": "#F5C518" }
        },
        "editorConfig": [
            {
                "label": "Data display",
                "layout": [
                    [ { "editor": "editor.number",   "label": "Minimum value", "option": "minValue" } ],
                    [ { "editor": "editor.number",   "label": "Maximum value", "option": "maxValue" } ],
                    [ { "editor": "editor.checkbox", "label": "Show label",    "option": "showLabel" } ]
                ]
            },
            {
                "label": "Color and style",
                "layout": [
                    [ { "editor": "editor.text",   "label": "Theme (auto/dark/light)", "option": "themeMode" } ],
                    [ { "editor": "editor.number", "label": "Arc width (px)",          "option": "arcWidth" } ],
                    [ { "editor": "editor.color",  "label": "Accent color",            "option": "accentColor" } ]
                ]
            }
        ]
    }
}
