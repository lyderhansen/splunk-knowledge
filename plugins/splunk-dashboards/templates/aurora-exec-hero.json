{
  "title": "Executive Hero",
  "description": "Aurora flagship — exec theme. 4 KPIs + primary trend with compare-to-previous. Leadership-ready.",
  "theme": "light",
  "dataSources": {
    "ds_1": {
      "type": "ds.search",
      "name": "Revenue",
      "options": {"query": "| makeresults count=7 | streamstats count as d | eval _time=_time - ((7-d) * 86400), rev=2200000 + (d * 30000) + (random() % 20000) | sort _time | table _time rev"}
    },
    "ds_2": {
      "type": "ds.search",
      "name": "Users",
      "options": {"query": "| makeresults count=7 | streamstats count as d | eval _time=_time - ((7-d) * 86400), users=1100 + (d * 26) + (random() % 10) | sort _time | table _time users"}
    },
    "ds_3": {
      "type": "ds.search",
      "name": "Churn",
      "options": {"query": "| makeresults count=7 | streamstats count as d | eval _time=_time - ((7-d) * 86400), churn=1.5 + (d * 0.09) | sort _time | table _time churn"}
    },
    "ds_4": {
      "type": "ds.search",
      "name": "MRR",
      "options": {"query": "| makeresults count=7 | streamstats count as d | eval _time=_time - ((7-d) * 86400), mrr=180000 + (d * 2500) + (random() % 500) | sort _time | table _time mrr"}
    },
    "ds_5": {
      "type": "ds.search",
      "name": "Growth trajectory",
      "options": {"query": "| makeresults count=30 | streamstats count | eval _time=_time - (count*86400), revenue=1800000 + (count*20000)+random() % 100000 | table _time revenue"}
    }
  },
  "visualizations": {
    "viz_revenue": {
      "type": "splunk.singlevalue",
      "title": "Monthly Revenue",
      "dataSources": {"primary": "ds_1"},
      "options": {
        "majorValue": "> primary | seriesByName('rev') | lastPoint()",
        "unit": "$",
        "unitPosition": "before",
        "majorValueSize": 48
      }
    },
    "viz_users": {
      "type": "splunk.singlevalue",
      "title": "New Users",
      "dataSources": {"primary": "ds_2"},
      "options": {
        "majorValue": "> primary | seriesByName('users') | lastPoint()",
        "majorValueSize": 28
      }
    },
    "viz_churn": {
      "type": "splunk.singlevalue",
      "title": "Churn",
      "dataSources": {"primary": "ds_3"},
      "options": {
        "majorValue": "> primary | seriesByName('churn') | lastPoint()",
        "unit": "%",
        "majorValueSize": 28
      },
      "gaugeRanges": [
        {"from": 0, "to": 2, "value": "#2B9E44"},
        {"from": 2, "to": 5, "value": "#D4820A"},
        {"from": 5, "to": 10, "value": "#C0392B"}
      ]
    },
    "viz_mrr": {
      "type": "splunk.singlevalue",
      "title": "MRR",
      "dataSources": {"primary": "ds_4"},
      "options": {
        "majorValue": "> primary | seriesByName('mrr') | lastPoint()",
        "unit": "$",
        "unitPosition": "before",
        "majorValueSize": 28
      }
    },
    "viz_trend": {
      "type": "splunk.line",
      "title": "Revenue trajectory",
      "dataSources": {"primary": "ds_5"},
      "options": {}
    }
  },
  "inputs": {
    "input_global_time": {
      "type": "input.timerange",
      "title": "Time range",
      "options": {"token": "global_time", "defaultValue": "-30d@d,now"}
    }
  },
  "defaults": {
    "dataSources": {
      "ds.search": {
        "options": {
          "queryParameters": {
            "earliest": "$global_time.earliest$",
            "latest": "$global_time.latest$"
          }
        }
      }
    }
  },
  "layout": {
    "type": "absolute",
    "globalInputs": ["input_global_time"],
    "options": {"width": 1440, "height": 700},
    "structure": [
      {"item": "viz_revenue", "type": "block", "position": {"x": 20,   "y": 60,  "w": 420, "h": 180}},
      {"item": "viz_users",   "type": "block", "position": {"x": 460,  "y": 60,  "w": 300, "h": 180}},
      {"item": "viz_churn",   "type": "block", "position": {"x": 780,  "y": 60,  "w": 300, "h": 280}},
      {"item": "viz_mrr",     "type": "block", "position": {"x": 1100, "y": 60,  "w": 320, "h": 180}},
      {"item": "viz_trend",   "type": "block", "position": {"x": 20,   "y": 360, "w": 1400, "h": 320}}
    ]
  }
}
