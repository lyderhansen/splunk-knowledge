    "viz_brand_wordmark": {
      "type": "splunk.markdown",
      "options": {
        "markdown": "# FAKE T-Shirt Co. \u2014 Retail Pulse",
        "fontColor": "#00D2FF",
        "fontSize": "extraLarge",
        "backgroundColor": "transparent"
