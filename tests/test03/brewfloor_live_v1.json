        "strokeColor": "#3D5A3F",
        "strokeWidth": 1,
        "rx": 10
      }
    },
    "viz_table_batches": {
      "type": "splunk.table",
      "title": "ACTIVE BATCHES",
      "dataSources": { "primary": "ds_batches" },
      "options": {
        "backgroundColor": "transparent",
        "rowBackgroundColors": "> table | seriesByName('progress') | rangeValue(progressColors)",
        "count": 10
      },
      "context": {
        "progressColors": [
          { "from": 80, "value": "transparent" },
          { "from": 40, "to": 80, "value": "transparent" },
          { "to": 40, "value": "transparent" }
        ]
      },
      "eventHandlers": [
        { "type": "drilldown.linkToSearch", "options": { "search": "index=brewery sourcetype=beerware_batch batch_id=$row.batch_id$" } }
      ]
    },
    "viz_card_alerts": {
      "type": "splunk.rectangle",
      "options": {
        "fillColor": "#1F2820",
        "fillOpacity": 1.0,
        "strokeColor": "#3D5A3F",
        "strokeWidth": 1,
        "rx": 10
      }
    },
    "viz_table_alerts": {
      "type": "splunk.table",
