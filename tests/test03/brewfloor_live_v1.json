        "fontFamily": "Splunk Platform Sans",
        "fontSize": "large",
        "markdown": "## Fermentation Trends & Quality"
      }
    },
    "viz_card_curves": {
      "type": "splunk.rectangle",
      "options": {
        "fillColor": "#1F2820",
        "fillOpacity": 1.0,
        "strokeColor": "#3D5A3F",
        "strokeWidth": 1,
        "rx": 10
      }
    },
    "viz_curves": {
      "type": "splunk.line",
      "title": "FERMENTATION CURVES — LAST 48H",
      "dataSources": { "primary": "ds_fermentation_curves" },
      "options": {
        "backgroundColor": "transparent",
        "seriesColors": ["#22C55E", "#7DD87D", "#B5651D", "#D49060"],
        "lineWidth": 2,
        "showRoundedY": false,
        "legendDisplay": "bottom",
        "xAxisTitleVisibility": "hide",
        "yAxisTitleText": "Plato",
        "yAxisTitleVisibility": "show",
        "xAxisLabelVisibility": "auto"
      },
      "eventHandlers": [
        { "type": "drilldown.linkToSearch", "options": { "search": "index=brewery sourcetype=opcua_tank earliest=-48h | timechart span=15m avg(plato) by tank_id" } }
      ]
    },
    "viz_card_do": {
      "type": "splunk.rectangle",
      "options": {
        "fillColor": "#1F2820",
