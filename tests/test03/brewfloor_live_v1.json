{
  "title": "Fjellbryggeri — Brewfloor Live",
  "description": "Real-time brewfloor decision support: 8-tank state, fermentation trends, quality alerts, CIP status. Designed for the wall above the brewfloor and the brewmaster's tablet during shift.",
  "theme": "dark",
  "dataSources": {
    "ds_kpi_active_tanks": {
      "type": "ds.search",
      "name": "Active tanks count",
      "options": {
        "query": "| makeresults | eval active_tanks=8 | table active_tanks",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_kpi_quality_alerts": {
      "type": "ds.search",
      "name": "Open quality alerts",
      "options": {
        "query": "| makeresults | eval open_alerts=2 | table open_alerts",
        "queryParameters": { "earliest": "-24h", "latest": "now" },
        "refresh": "60s",
        "refreshType": "delay"
      }
    },
    "ds_kpi_batches_onspec": {
      "type": "ds.search",
      "name": "Batches on spec count",
      "options": {
        "query": "| makeresults | eval on_spec=5 | table on_spec",
        "queryParameters": { "earliest": "-24h", "latest": "now" },
        "refresh": "60s",
        "refreshType": "delay"
      }
    },
    "ds_kpi_next_step": {
      "type": "ds.search",
      "name": "Next critical step minutes",
      "options": {
        "query": "| makeresults | eval minutes=47 | table minutes",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl01": {
      "type": "ds.search",
      "name": "Tank BL01 state",
      "options": {
        "query": "| makeresults | eval temp=18.2 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl02": {
      "type": "ds.search",
      "name": "Tank BL02 state",
      "options": {
        "query": "| makeresults | eval temp=20.1 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl03": {
      "type": "ds.search",
      "name": "Tank BL03 state",
      "options": {
        "query": "| makeresults | eval temp=19.5 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl04": {
      "type": "ds.search",
      "name": "Tank BL04 state",
      "options": {
        "query": "| makeresults | eval temp=22.0 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl05": {
      "type": "ds.search",
      "name": "Tank BL05 state",
      "options": {
        "query": "| makeresults | eval temp=4.0 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl06": {
      "type": "ds.search",
      "name": "Tank BL06 state",
      "options": {
        "query": "| makeresults | eval temp=18.7 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl07": {
      "type": "ds.search",
      "name": "Tank BL07 state",
      "options": {
        "query": "| makeresults | eval temp=2.5 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_tank_bl08": {
      "type": "ds.search",
      "name": "Tank BL08 state",
      "options": {
        "query": "| makeresults | eval temp=19.8 | table temp",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "30s",
        "refreshType": "delay"
      }
    },
    "ds_fermentation_curves": {
      "type": "ds.search",
      "name": "Fermentation curves 48h",
      "options": {
        "query": "| makeresults count=48 | streamstats count as i | eval _time = relative_time(now(), \"-\".(48-i).\"h\") | eval BL01 = max(2, round(14 - 0.25*i + 0.6*sin(i/3), 2)) | eval BL02 = max(2, round(13 - 0.22*i + 0.5*sin(i/4), 2)) | eval BL06 = max(2, round(14 - 0.20*i + 0.4*sin(i/3), 2)) | eval BL08 = max(2, round(13.5 - 0.21*i + 0.5*sin(i/2), 2)) | sort _time | table _time BL01 BL02 BL06 BL08",
        "queryParameters": { "earliest": "-48h", "latest": "now" },
        "refresh": "120s",
        "refreshType": "delay"
      }
    },
    "ds_dissolved_oxygen": {
      "type": "ds.search",
      "name": "Dissolved oxygen by sample point",
      "options": {
        "query": "| makeresults | eval point=\"Boil-out\", do_ppb=42 | append [| makeresults | eval point=\"Post-Knockout\", do_ppb=18] | append [| makeresults | eval point=\"Post-Fermentation\", do_ppb=8] | append [| makeresults | eval point=\"Bottling\", do_ppb=12] | table point do_ppb",
        "queryParameters": { "earliest": "-24h", "latest": "now" },
        "refresh": "300s",
        "refreshType": "delay"
      }
    },
    "ds_batches": {
      "type": "ds.search",
      "name": "Active batches progress",
      "options": {
        "query": "| makeresults | eval batch_id=\"2026-128\", recipe=\"Sommernatt Pilsner\", stage=\"Fermentation D5/7\", progress=71, eta=\"2 days\" | append [| makeresults | eval batch_id=\"2026-127\", recipe=\"Voss IPA\", stage=\"Fermentation D6/7\", progress=86, eta=\"1 day\"] | append [| makeresults | eval batch_id=\"2026-126\", recipe=\"Tjaere Stout\", stage=\"Conditioning D8/14\", progress=57, eta=\"6 days\"] | append [| makeresults | eval batch_id=\"2026-125\", recipe=\"Sommernatt Pilsner\", stage=\"Cold Crash D2/3\", progress=67, eta=\"1 day\"] | append [| makeresults | eval batch_id=\"2026-124\", recipe=\"Julestjerne\", stage=\"Conditioning D12/14\", progress=86, eta=\"2 days\"] | append [| makeresults | eval batch_id=\"2026-129\", recipe=\"Voss IPA\", stage=\"Boil active\", progress=22, eta=\"in tank now\"] | append [| makeresults | eval batch_id=\"2026-130\", recipe=\"Sommernatt Pilsner\", stage=\"Fermentation D3/7\", progress=43, eta=\"4 days\"] | append [| makeresults | eval batch_id=\"2026-131\", recipe=\"Tjaere Stout\", stage=\"Fermentation D4/7\", progress=57, eta=\"3 days\"] | table batch_id recipe stage progress eta",
        "queryParameters": { "earliest": "-15m", "latest": "now" },
        "refresh": "300s",
        "refreshType": "delay"
      }
    },
    "ds_alerts": {
      "type": "ds.search",
      "name": "Quality alerts last 24h",
      "options": {
        "query": "| makeresults count=8 | streamstats count as i | eval _time = relative_time(now(), \"-\".(i*47).\"m\") | eval tank_id = case(i==1,\"BL04\",i==2,\"BL01\",i==3,\"BL07\",i==4,\"BL02\",i==5,\"BL05\",i==6,\"BL08\",i==7,\"BL03\",true(),\"BL06\") | eval alert_type = case(i==1,\"DO out of spec\",i==2,\"Temp deviation\",i==3,\"Pressure low\",i==4,\"Sensor fault\",i==5,\"CIP overdue\",i==6,\"Gravity stall\",i==7,\"DO spike\",true(),\"Temp deviation\") | eval severity = case(i==1,\"WARN\",i==2,\"WARN\",i==3,\"OK\",i==4,\"OK\",i==5,\"WARN\",i==6,\"OK\",i==7,\"OK\",true(),\"OK\") | eval message = case(i==1,\"DO 42 ppb at boil-out (limit 30)\",i==2,\"Temp drift +1.2C from setpoint\",i==3,\"Pressure recovered automatically\",i==4,\"Sensor reseated by Ingrid\",i==5,\"CIP cycle 4h overdue\",i==6,\"Gravity unchanged 6h, intervention applied\",i==7,\"DO spike during sampling\",true(),\"Minor drift, auto-corrected\") | eval ack = case(i==1,\"\",i==2,\"\",i==3,\"ingrid\",i==4,\"lars\",i==5,\"\",i==6,\"ingrid\",i==7,\"karl\",true(),\"karl\") | sort - _time | table _time tank_id alert_type severity message ack",
        "queryParameters": { "earliest": "-24h", "latest": "now" },
        "refresh": "60s",
        "refreshType": "delay"
      }
    },
    "ds_cip_status": {
      "type": "ds.search",
      "name": "CIP cycle status by tank",
      "options": {
        "query": "| makeresults | eval tank=\"BL01\", last_clean=\"2026-04-29 02:14\", hours_since=12, result=\"PASS\" | append [| makeresults | eval tank=\"BL02\", last_clean=\"2026-04-28 22:00\", hours_since=16, result=\"PASS\"] | append [| makeresults | eval tank=\"BL03\", last_clean=\"2026-04-28 18:30\", hours_since=20, result=\"PASS\"] | append [| makeresults | eval tank=\"BL04\", last_clean=\"2026-04-28 04:00\", hours_since=34, result=\"PASS\"] | append [| makeresults | eval tank=\"BL05\", last_clean=\"2026-04-26 14:00\", hours_since=72, result=\"OVERDUE\"] | append [| makeresults | eval tank=\"BL06\", last_clean=\"2026-04-29 09:00\", hours_since=5, result=\"PASS\"] | append [| makeresults | eval tank=\"BL07\", last_clean=\"2026-04-27 11:00\", hours_since=51, result=\"PASS\"] | append [| makeresults | eval tank=\"BL08\", last_clean=\"2026-04-29 05:00\", hours_since=9, result=\"PASS\"] | table tank last_clean hours_since result",
        "queryParameters": { "earliest": "-7d", "latest": "now" },
        "refresh": "300s",
        "refreshType": "delay"
      }
    }
  },
