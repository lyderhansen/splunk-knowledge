{
  "title": "ACME Daily Controls",
  "description": "CISO daily control validation. Dark trading-floor palette via ui-ux-pro-max financial-dashboard.",
  "defaults": {
    "dataSources": {
      "ds.search": {
        "options": {
          "queryParameters": {
            "earliest": "-24h@h",
            "latest": "now"
          }
        }
      }
    },
    "visualizations": {
      "global": {
        "showLastUpdated": false
      }
    }
  },
  "inputs": {},
  "dataSources": {
    "kpi_critical_incidents": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,2,day=2,3,day=3,1,day=4,4,day=5,2,day=6,1,day=7,3,day=8,5,day=9,2,day=10,1,day=11,2,day=12,1,day=13,0,day=14,0) | table _time count"
      },
      "name": "kpi_critical_incidents"
    },
    "kpi_edr_coverage": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval pct = case(day=1,93.2,day=2,93.8,day=3,94.5,day=4,94.1,day=5,95.0,day=6,95.3,day=7,95.0,day=8,95.5,day=9,95.8,day=10,96.0,day=11,95.7,day=12,96.2,day=13,96.0,day=14,96.4) | table _time pct"
      },
      "name": "kpi_edr_coverage"
    },
    "kpi_patch_compliance": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval pct = case(day=1,89.5,day=2,89.0,day=3,88.5,day=4,88.0,day=5,87.5,day=6,87.0,day=7,86.5,day=8,86.0,day=9,85.5,day=10,85.0,day=11,86.0,day=12,86.5,day=13,87.0,day=14,87.3) | table _time pct"
      },
      "name": "kpi_patch_compliance"
    },
    "kpi_alerts_triaged": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,135,day=2,128,day=3,140,day=4,155,day=5,148,day=6,132,day=7,138,day=8,145,day=9,152,day=10,128,day=11,135,day=12,140,day=13,144,day=14,142) | table _time count"
      },
      "name": "kpi_alerts_triaged"
    },
    "tile_incidents_24h": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,5,day=2,8,day=3,12,day=4,9,day=5,7,day=6,4,day=7,6,day=8,11,day=9,8,day=10,9,day=11,7,day=12,6,day=13,8,day=14,7) | table _time count"
      },
      "name": "tile_incidents_24h"
    },
    "tile_open_cases": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,18,day=2,16,day=3,17,day=4,15,day=5,14,day=6,13,day=7,15,day=8,14,day=9,13,day=10,12,day=11,11,day=12,12,day=13,13,day=14,12) | table _time count"
      },
      "name": "tile_open_cases"
    },
    "tile_failed_logins": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,180,day=2,210,day=3,195,day=4,220,day=5,205,day=6,240,day=7,225,day=8,250,day=9,235,day=10,215,day=11,225,day=12,240,day=13,228,day=14,234) | table _time count"
      },
      "name": "tile_failed_logins"
    },
    "tile_dns_suspicious": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=3,1,day=8,2,day=12,1,1==1,0) | table _time count"
      },
      "name": "tile_dns_suspicious"
    },
    "tile_critical_vulns": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,4,day=2,4,day=3,5,day=4,5,day=5,4,day=6,4,day=7,3,day=8,3,day=9,4,day=10,4,day=11,3,day=12,3,day=13,3,day=14,3) | table _time count"
      },
      "name": "tile_critical_vulns"
    },
    "tile_untested_controls": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval count = case(day=1,4,day=2,3,day=3,3,day=4,2,day=5,2,day=6,2,day=7,1,day=8,1,day=9,2,day=10,1,day=11,1,day=12,1,day=13,1,day=14,1) | table _time count"
      },
      "name": "tile_untested_controls"
    },
    "trend_incidents_14d": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=14 | streamstats count as day | eval _time = now() - 86400 * (14 - day) | eval incidents = case(day=1,8,day=2,6,day=3,7,day=4,9,day=5,5,day=6,4,day=7,6,day=8,12,day=9,10,day=10,7,day=11,5,day=12,4,day=13,3,day=14,2) | table _time incidents"
      },
      "name": "trend_incidents_14d"
    },
    "controls_grid": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=10 | streamstats count as i | eval domain=case(i<=2, \"Endpoint\", i<=4, \"Identity\", i<=6, \"Network\", i<=8, \"Data\", 1==1, \"Cloud\") | eval control=case(i=1, \"EDR Coverage\", i=2, \"Disk Encryption\", i=3, \"MFA Enforcement\", i=4, \"PAM Sessions\", i=5, \"Egress Monitoring\", i=6, \"DNS Filtering\", i=7, \"DLP Coverage\", i=8, \"Backup Validation\", i=9, \"Cloud Posture\", 1==1, \"Container Scanning\") | eval status=case(i=2, \"DEGRADED\", i=7, \"FAILED\", 1==1, \"OK\") | eval status_glyph=case(status=\"OK\", \"OK \u2713\", status=\"DEGRADED\", \"DEGRADED \u26a0\", status=\"FAILED\", \"FAILED \u2717\") | eval last_tested=strftime(now()-3600*case(i=2,2, i=7,1, 1==1,12), \"%b %d %H:%M\") | rename domain as Domain control as Control status_glyph as Status last_tested as \"Last Tested\" | table Domain Control Status \"Last Tested\""
      },
      "name": "controls_grid"
    }
  },
  "visualizations": {
    "viz_brand_icon": {
      "type": "splunk.choropleth.svg",
      "options": {
        "svg": "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23FF2942' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M12 2L4 6v6c0 5.5 3.8 10.7 8 12 4.2-1.3 8-6.5 8-12V6l-8-4z'/></svg>",
        "backgroundColor": "transparent"
      },
      "context": {},
      "containerOptions": {},
      "showProgressBar": false,
      "showLastUpdated": false
